# Tier-2 test-target identifiers. Each forge is optional; blank skips
# that forge's tests. Copy this file to $HF_V5_TEST_CONFIG_DIR/tier2.env
# and fill in real, disposable repo names.
#
# The referenced repos MUST already exist on the forge and be owned by
# the configured credentials. Tests that push metadata (V5REPOS-14)
# update the `description` field and restore the original — use a
# sandbox repo, not a load-bearing one.

HF_TIER2_GITHUB_ORG=
HF_TIER2_GITHUB_REPO=
# Optional: token for scripts that seed cred refs in local fixtures
# (e.g. V5WS-9 uses `secrets://gh-token`, which isn't a prod key shape).
# Most tier-2 scripts read creds through the overlaid secrets.yaml and
# don't need these TOKEN vars.
HF_TIER2_GITHUB_TOKEN=

HF_TIER2_CODEBERG_ORG=
HF_TIER2_CODEBERG_REPO=
HF_TIER2_CODEBERG_TOKEN=

HF_TIER2_GITLAB_ORG=
HF_TIER2_GITLAB_REPO=
HF_TIER2_GITLAB_TOKEN=
